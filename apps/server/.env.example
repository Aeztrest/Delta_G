PORT=8080
LOG_LEVEL=info
NODE_ENV=development

# Comma-separated API keys (at least one required in production)
DELTAG_API_KEYS=dev-key-change-me

# RPC endpoints per cluster (required for analyze + ready)
RPC_MAINNET_BETA=https://api.mainnet-beta.solana.com
RPC_DEVNET=https://api.devnet.solana.com
RPC_TESTNET=https://api.testnet.solana.com

# Optional: comma-separated program IDs treated as risky
RISKY_PROGRAM_IDS=

# Optional: comma-separated program IDs; when set, any other program in tx = unknown exposure
KNOWN_SAFE_PROGRAM_IDS=11111111111111111111111111111111,TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA,ATokenGPvbdGVxr1b2hvZbsiqW5xWH25efTNsLJA8knL,ComputeBudget111111111111111111111111111111

# USDC mint per cluster (mainnet default)
USDC_MINT_MAINNET=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
USDC_MINT_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_MINT_TESTNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# Max accounts to fetch for delta analysis (caps RPC payload)
MAX_SIMULATION_ACCOUNTS=64

# Request limits
MAX_BODY_BYTES=1048576
REQUEST_TIMEOUT_MS=25000

# Reverse proxy / Docker nginx arkası: gerçek istemci IP (rate limit, log)
DELTAG_TRUST_PROXY=

# --- x402 (HTTP 402 + Solana USDC, optional; see https://docs.x402.org ) ---
# Set to true to charge per POST /v1/analyze via x402 (Solana exact scheme).
X402_ENABLED=false
# Receiver Solana address (base58). Required when X402_ENABLED=true
X402_PAY_TO=
# Default test facilitator (Solana devnet): https://x402.org/facilitator
# Production / gasless Solana: https://facilitator.payai.network (verify network support)
X402_FACILITATOR_URL=https://x402.org/facilitator
# CAIP-2 network id (devnet default matches public facilitator)
# Mainnet: solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp
X402_NETWORK=solana:EtWTRABZaYq6iMfeYKouRu166VU2xqa1
X402_ANALYZE_PRICE=$0.001
# api_key | x402 | both — who may call /v1/analyze (when X402_ENABLED=true, default is both if API keys exist else x402)
DELTAG_AUTH_MODE=
